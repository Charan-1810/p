{
  "name": "@ace/auth-service",
  "version": "1.0.0",
  "description": "Authentication service for AI Codebase Explainer",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e ../../../.env -- ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node -r ts-node/register src/migrations/run.ts",
    "test": "jest --forceExit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ace/shared": "*",
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "fastify-plugin": "^4.5.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.7.2",
    "zod": "^3.23.8",
    "uuid": "^9.0.1",
    "pino": "^8.19.0",
    "pino-pretty": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.4"
  }
}
